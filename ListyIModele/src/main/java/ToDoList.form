<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ToDoList">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="3e24b" binding="panelInput" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="e2387" class="javax.swing.JTextField" binding="itemInput">
            <constraints border-constraint="First"/>
            <properties/>
          </component>
        </children>
      </grid>
      <grid id="f0023" binding="panelList" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="13144" binding="panelDelete" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="South"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="583fd" class="javax.swing.JButton" binding="deleteButton">
                <constraints border-constraint="First"/>
                <properties>
                  <text value="Usuń"/>
                </properties>
              </component>
              <grid id="b4c34" binding="panelCounter" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="South"/>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="8dce0" class="javax.swing.JLabel" binding="Counter">
                    <constraints border-constraint="First"/>
                    <properties>
                      <text value="Liczba zadań: "/>
                    </properties>
                  </component>
                </children>
              </grid>
            </children>
          </grid>
          <scrollpane id="7d227">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="4dd3a" class="javax.swing.JList" binding="ItemList">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
        </children>
      </grid>
      <grid id="a71fe" binding="panelAdd" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="West"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="937d2" class="javax.swing.JButton" binding="addButton">
            <constraints border-constraint="West"/>
            <properties>
              <text value="Dodaj"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
